<?xml version="1.0"?>
<addons>
    <addon id="repository.demo" name="Demo Repo" version="1.0.2" provider-name="Demo">
        <extension point="xbmc.addon.repository">
            <dir>
                <info>https://guillemc97.github.io/Kodi/addons.xml</info>
                <checksum>https://guillemc97.github.io/Kodi/addons.xml.md5</checksum>
                <datadir zip="true">https://guillemc97.github.io/Kodi/</datadir>
            </dir>
        </extension>
    </addon>
    <addon id="plugin.video.demo"
        name="Demo Video"
        version="1.0.2"
        provider-name="Demo">

        <requires>
            <import addon="xbmc.python" version="3.0.0" />
        </requires>

        <extension
            point="xbmc.python.pluginsource"
            library="addon.py">
            <provides>video</provides>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>Addon de ejemplo</summary>
            <description>Primer addon del repositorio.</description>
            <platform>all</platform>
        </extension>

    </addon>
</addons>