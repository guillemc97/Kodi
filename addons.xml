<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.foto.demo"
       name="Fotos"
       version="1.0.3"
       provider-name="Imagenes">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.addon.metadata">
        <summary lang="es_ES">Instalar repositorios 2</summary>
        <description lang="es_ES">Descage los repos disponibles</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>

</addon>
<addon id="plugin.program.repoinstaller"
    name="Instalar repositorios"
    version="1.0.5"
    provider-name="Guillem">

    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>

    <extension point="xbmc.python.script"
        library="addon.py" />

    <extension point="xbmc.addon.metadata">
        <summary lang="es_ES">Instalar repositorios 2</summary>
        <description lang="es_ES">Descage los repos disponibles</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>

</addon>
<addon id="repository.demo"
    name="Repo"
    version="1.0.6"
    provider-name="Guillem">

    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>

    <extension point="xbmc.addon.repository">
        <dir>
            <info compressed="false">
                https://guillemc97.github.io/Kodi/addons.xml
            </info>

            <checksum>
                https://guillemc97.github.io/Kodi/addons.xml.md5
            </checksum>

            <datadir zip="true">
                https://guillemc97.github.io/Kodi/
            </datadir>
        </dir>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Guillem repositorio</summary>
        <description>Este repositorio esta diseñado para envia y facilitar para repositores nuevos</description>
        <assets>
            <icon>icon.png</icon>
        </assets>
        <platform>all</platform>
    </extension>

</addon>

</addons>