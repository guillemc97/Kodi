<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.foto.kodi"
    name="Fotos"
    version="1.0.9"
    provider-name="Imagenes">

    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>

    <extension point="xbmc.python.pluginsource"
        library="addon.py">
        <provides>image</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary lang="es_ES">Instalar Imagenes</summary>
        <description lang="es_ES">Nuevas imagenes en el repo</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
<addon id="plugin.program.repoinstaller"
    name="Instalar repositorios"
    version="1.0.5"
    provider-name="Guillem">

    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>

    <extension point="xbmc.python.script"
        library="addon.py" />

    <extension point="xbmc.addon.metadata">
        <summary lang="es_ES">Instalar repositorios 2</summary>
        <description lang="es_ES">Descage los repos disponibles</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>

</addon>
<addon id="repository.kodi"
    name="Guillem Repo"
    version="1.1.0"
    provider-name="Guillem">

    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>

    <extension point="xbmc.addon.repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/guillemc97/Kodi/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/guillemc97/Kodi/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/guillemc97/Kodi/main/</datadir>
        </dir>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Guillem repositorio</summary>
        <description>Este repositorio esta diseñado para envia y facilitar para repositores nuevos</description>
        <assets>
            <icon>icon.png</icon>
        </assets>
        <platform>all</platform>
    </extension>

</addon>

</addons>