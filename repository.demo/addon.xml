<?xml version="1.0" encoding="UTF-8"?>
<addon id="repository.demo"
    name="Repo"
    version="1.0.3"
    provider-name="Guillem">

    <requires>
        <import addon="xbmc.addon" version="20.0.0" />
    </requires>

    <extension point="xbmc.addon.repository">
        <dir>
            <info compressed="false">
                https://guillemc97.github.io/Kodi/addons.xml
            </info>

            <checksum>
                https://guillemc97.github.io/Kodi/addons.xml.md5
            </checksum>

            <datadir zip="true">
                https://guillemc97.github.io/Kodi/
            </datadir>
        </dir>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Bugatsinho repository</summary>
        <description>This repository contains Greek, Spanish and other addons!Read first each
            addon's description!</description>
        <assets>
            <icon>icon.png</icon>
        </assets>
        <platform>all</platform>
    </extension>

</addon>